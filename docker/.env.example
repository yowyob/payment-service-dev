# ── APPLICATION ──────────────────────────────
APP_PORT=8080
APP_NAME=yowyob-payment
APP_ENV=development

# ── BASE DE DONNÉES ──────────────────────────
# DB_PORT = port exposé sur la machine hôte (mapping docker : "${DB_PORT}:5432")
# En dev local (mvn spring-boot:run), utiliser DB_HOST=localhost et ce DB_PORT
DB_HOST=localhost
DB_PORT=5432
DB_NAME=yowyob_payment
DB_USER=yowyob
DB_PASSWORD=secret
DB_POOL_MIN=2
DB_POOL_MAX=10

# ── KERNEL / YOWAUTH ─────────────────────────
KERNEL_BASE_URL=https://kernel-core.yowyob.com
KERNEL_CLIENT_ID=<votre-client-id>
KERNEL_API_KEY=<votre-api-key>
KERNEL_TENANT_ID=<votre-tenant-id>
KERNEL_ISSUER=https://kernel-core.yowyob.com
PAYMENTS_ADMIN_PERMISSIONS=payments:admin

# ── REDIS ────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_TTL_SECONDS=300

# ── KAFKA ────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_TRANSACTION_EVENTS=yowyob.transaction.events
KAFKA_TOPIC_WALLET_EVENTS=yowyob.wallet.events
KAFKA_GROUP_ID=yowyob-payment-group
ZOOKEEPER_PORT=2181
KAFKA_PORT=9092

# ── FRAIS DE TRANSACTION ─────────────────────
WITH_FEES=false
FEE_TYPE=PERCENTAGE
FEE_VALUE=0.1
FEE_CURRENCY=XAF

# ── STRIPE ───────────────────────────────────
STRIPE_PUBLISHABLE_KEY=pk_test_placeholder
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder
STRIPE_SUCCESS_URL=http://localhost:8080/api/v1/stripe/success
STRIPE_CANCEL_URL=http://localhost:8080/api/v1/stripe/cancel
STRIPE_CURRENCY=eur

# ── SWAGGER ──────────────────────────────────
SWAGGER_TITLE=Yowyob Payment API
SWAGGER_DESCRIPTION=API pour la gestion des paiements, wallets et transactions (auth kernel).
SWAGGER_VERSION=1.0.0
SWAGGER_SERVER_URL=http://localhost:8080

# ── TRANSACTION ──────────────────────────────
TRANSACTION_REFERENCE_PREFIX=TXN
MIN_TRANSACTION_AMOUNT=100
MAX_TRANSACTION_AMOUNT=10000000
MAX_WALLET_BALANCE=50000000
